# ─── 9Router (AI Proxy) ────────────────────────────────
# Local:  http://127.0.0.1:20128/v1
# Docker: http://9router:20128/v1
NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINE_ROUTER_MODEL=ocg/mimo-v2.5

# ─── Redis (Session Store) ─────────────────────────────
# Local:  redis://127.0.0.1:6379
# Docker: redis://redis:6379
REDIS_URL=redis://127.0.0.1:6379

# ─── SearXNG (Web Search) ──────────────────────────────
# Local:  http://127.0.0.1:4000
# Docker: http://searxng:8080
SEARXNG_BASE_URL=http://127.0.0.1:4000

# ─── Bot Behavior ───────────────────────────────────────
SELF_RESPON=false            # true = bot bales chat sendiri (testing)
ALLOWED_NUMBERS=*            # * = semua, atau: 62812,62813

# ─── App ────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info              # debug | info | warn | error
