# ─── 9Router (AI Proxy) ────────────────────────────────
# Local:  http://127.0.0.1:52012/v1
# Docker: http://9router:20128/v1
NINE_ROUTER_BASE_URL=http://127.0.0.1:52012/v1
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_API_KEY=                # isi dari dashboard 9Router (kalo remote/VPS)

# ─── Redis (Session Store) ─────────────────────────────
# Local:  redis://127.0.0.1:56379
# Docker: redis://redis:6379
REDIS_URL=redis://127.0.0.1:56379

# ─── SearXNG (Web Search) ──────────────────────────────
# Local:  http://127.0.0.1:54000
# Docker: http://searxng:8080
SEARXNG_BASE_URL=http://127.0.0.1:54000

# ─── Bot Behavior ───────────────────────────────────────
SELF_RESPON=false            # true = bot bales chat sendiri (testing)
ALLOWED_NUMBERS=*            # * = semua, self = diri sendiri, atau: 62812,self

# ─── App ────────────────────────────────────────────────
PORT=53000
DATA_DIR=.                  # direktori penyimpanan DB
LOG_LEVEL=info              # debug | info | warn | error
